<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE wml PUBLIC "-//WAPFORUM//DTD WML 1.3//EN" "http://www.wapforum.org/DTD/wml13.dtd">
<wml>
  <card id="card1" title="WML Base Test">
    <p align="center">
      <b>WML Kernel Test Page</b><br/>
      <small>Version 1.3 Compatible</small>
    </p>
    <p>
      Go to <a href="#card2">Next Card (Form Test)</a><br/>
      <timer value="30"/>
    </p>
  </card>

  <card id="card2" title="Form Test">
    <p>
      Enter Name:
      <input name="username" size="12" maxlength="20" emptyok="false"/>
      
      Select Gender:
      <select name="gender" value="M">
        <option value="M">Male</option>
        <option value="F">Female</option>
      </select>
    </p>
    
    <do type="accept" label="Submit">
      <go href="#card3" method="post">
        <postfield name="user" value="$(username)"/>
        <postfield name="sex" value="$(gender)"/>
      </go>
    </do>
  </card>

  <card id="card3" title="Result">
    <p>
      Hello, $(username)!<br/>
      <img src="test_image.wbmp" alt="[WBMP Icon]"/>
    </p>
    <do type="prev" label="Back">
      <prev/>
    </do>
  </card>
</wml>
